\examples{
\dontrun{
#Load example count data provided with the package
data(counts)
data(batch)
data(group)

#Run the resampling-based QC evaluation
results = QC_resample(counts, batches = batch, groups = group,
                      metrics = c("F-score", "Davies-Bouldin"),
                      iters = 5,
                      Ctrl_sample = "normal",
                      corrMethod = "ComBat",
                      parallel = FALSE)
}
}
